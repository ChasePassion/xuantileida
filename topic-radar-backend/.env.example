# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=topic_radar
DB_SYNC=false
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# WeChat Mini Program
WECHAT_APPID=wx1234567890abcdef
WECHAT_SECRET=your-wechat-secret

# External API (极致了API)
JIZHILE_API_KEY=your-api-key
JIZHILE_BASE_URL=https://www.dajiala.com

# 火山方舟 LLM
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-pro-260215

# Tencent COS
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET=topic-radar-bucket
COS_REGION=ap-guangzhou

# WeChat Pay
WECHAT_PAY_MCHID=1234567890
WECHAT_PAY_KEY=your-pay-key
WECHAT_PAY_CERT_PATH=/path/to/cert.pem
WECHAT_PAY_KEY_PATH=/path/to/key.pem
