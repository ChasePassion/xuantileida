/* ===== 全局变量 ===== */
page {
  --color-primary: #5B5FE6;
  --color-primary-light: #E8E9FC;
  --color-bg: #F5F6FA;
  --color-white: #ffffff;
  --color-text: #1A1A2E;
  --color-text-secondary: #6B7280;
  --color-text-hint: #9CA3AF;
  --color-border: #E5E7EB;
  --color-success: #10B981;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-douyin: #FE2C55;
  --color-kuaishou: #FF6600;
  --color-wechat: #07C160;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
}

/* ===== 通用卡片 ===== */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: var(--shadow-sm);
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-md);
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  padding: 18rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* ===== 徽章 ===== */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-primary {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.badge-douyin {
  background: rgba(254,44,85,0.1);
  color: var(--color-douyin);
}

.badge-kuaishou {
  background: rgba(255,102,0,0.1);
  color: var(--color-kuaishou);
}

.badge-wechat {
  background: rgba(7,193,96,0.1);
  color: var(--color-wechat);
}

/* ===== 布局工具 ===== */
.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* ===== 文字工具 ===== */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-hint { color: var(--color-text-hint); }
.text-bold { font-weight: 600; }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-state .empty-text {
  color: var(--color-text-hint);
  font-size: 28rpx;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 24rpx 0;
}

/* ===== 安全底部 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}
