.timeline {
  padding: 8rpx 0;
}

.timeline-item {
  display: flex;
  padding-bottom: 8rpx;
}

.tl-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  flex-shrink: 0;
}

.tl-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.tl-line {
  width: 3rpx;
  flex: 1;
  background: #E5E7EB;
  margin: 8rpx 0;
  min-height: 40rpx;
}

.tl-content {
  flex: 1;
  padding: 0 0 28rpx 16rpx;
}

.tl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tl-label {
  font-size: 28rpx;
  font-weight: 600;
}

.tl-time {
  font-size: 22rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tl-text {
  display: block;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  margin-top: 12rpx;
}

.tl-technique {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.technique-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.technique-text {
  font-size: 24rpx;
  color: #5B5FE6;
}
