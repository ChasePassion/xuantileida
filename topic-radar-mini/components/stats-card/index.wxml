<view class="stats-card">
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.topicCount}}</text>
      <text class="stat-label">今日选题</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.viralCount}}</text>
      <text class="stat-label">爆款视频</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.industryCount}}</text>
      <text class="stat-label">覆盖行业</text>
    </view>
  </view>
  <view class="stats-time" wx:if="{{stats.updateTime}}">
    <text class="time-text">更新于 {{stats.updateTime}}</text>
  </view>
</view>
