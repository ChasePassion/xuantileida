.topic-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  align-items: center;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-hot {
  background: linear-gradient(135deg, #FF6B6B, #EE5A24);
}

.rank-normal {
  background: #D1D5DB;
  color: #6B7280;
}

.card-title-wrap {
  flex: 1;
  overflow: hidden;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-category {
  font-size: 22rpx;
  color: #5B5FE6;
  background: rgba(91,95,230,0.08);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-top: 6rpx;
  display: inline-block;
}

.heat-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.heat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #EF4444;
  line-height: 1.2;
}

.heat-label {
  font-size: 20rpx;
  color: #9CA3AF;
}

.card-body {
  margin-top: 16rpx;
  padding-left: 68rpx;
}

.card-reason {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.5;
}

.card-footer {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  padding-left: 68rpx;
  border-top: 1rpx solid #F3F4F6;
}

.footer-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
}

.footer-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
  color: #9CA3AF;
}

.footer-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.footer-arrow {
  margin-left: auto;
  font-size: 36rpx;
  color: #D1D5DB;
}

/* 锁定状态 */
.topic-card.locked {
  position: relative;
  overflow: hidden;
  opacity: 0.7;
}

.lock-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
  border-radius: 24rpx;
}

.lock-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.lock-text {
  font-size: 24rpx;
  color: #5B5FE6;
  font-weight: 600;
}

.card-title.blurred {
  color: transparent;
  text-shadow: 0 0 16rpx rgba(26,26,46,0.5);
}
