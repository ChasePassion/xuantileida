.page-discover {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

/* 分类筛选 */
.category-scroll {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: #fff;
  margin-bottom: 8rpx;
}

.cat-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #F3F4F6;
}

.cat-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

.cat-count {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 600;
  background: rgba(0,0,0,0.08);
  color: #6B7280;
  border-radius: 16rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
}

.cat-item.active .cat-count {
  background: rgba(255,255,255,0.3);
  color: #fff;
}

/* 免费版提示条 */
.free-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(90deg, #FFF7ED, #FEF3C7);
  padding: 16rpx 24rpx;
  margin: 0 24rpx 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid #FDE68A;
}

.free-text {
  font-size: 24rpx;
  color: #92400E;
  flex: 1;
}

.free-btn {
  background: linear-gradient(135deg, #5B5FE6, #7C3AED);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 选题列表 */
.topic-list {
  padding-top: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #9CA3AF;
}

.empty-sub {
  font-size: 24rpx;
  color: #D1D5DB;
  margin-top: 12rpx;
}
