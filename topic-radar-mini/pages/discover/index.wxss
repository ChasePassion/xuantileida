.page-discover {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

/* 分类筛选 */
.category-scroll {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: #fff;
  margin-bottom: 8rpx;
}

.cat-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #F3F4F6;
}

.cat-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

/* 选题列表 */
.topic-list {
  padding-top: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #9CA3AF;
}

.empty-sub {
  font-size: 24rpx;
  color: #D1D5DB;
  margin-top: 12rpx;
}
