<view class="page-profile">
  <!-- 用户卡片 -->
  <view class="user-card">
    <view class="avatar-wrap">
      <image
        class="avatar"
        src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
        mode="aspectFill"
      />
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '未登录'}}</text>
      <text class="user-plan badge badge-primary">{{plan}}</text>
    </view>
  </view>

  <!-- 余额卡片 -->
  <view class="balance-card card">
    <view class="balance-header">
      <text class="balance-title">雷达币余额</text>
      <view class="recharge-btn" bind:tap="onMenuTap" data-url="/pages/recharge/index">
        <text>充值</text>
      </view>
    </view>
    <text class="balance-num">{{balance}}</text>
  </view>

  <!-- 使用统计 -->
  <view class="stats-card card">
    <view class="stat-row">
      <view class="stat-col">
        <text class="stat-num">{{stats.analyses || 0}}</text>
        <text class="stat-label">拆解报告</text>
      </view>
      <view class="stat-col">
        <text class="stat-num">{{stats.generations || 0}}</text>
        <text class="stat-label">AI生成</text>
      </view>
      <view class="stat-col">
        <text class="stat-num">{{stats.edits || 0}}</text>
        <text class="stat-label">编辑次数</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card card">
    <view
      class="menu-item"
      wx:for="{{menuItems}}"
      wx:key="key"
      data-url="{{item.url}}"
      bind:tap="onMenuTap"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-label">{{item.label}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
