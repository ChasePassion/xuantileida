.page-promo-notes {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #5B5FE6, #7C3AED);
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 规则卡片 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 24rpx;
  display: block;
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.rule-icon {
  width: 100rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.rule-icon.xiaohongshu {
  background: rgba(254,44,85,0.1);
  color: #FE2C55;
}

.rule-icon.douyin {
  background: rgba(0,0,0,0.05);
  color: #000;
}

.rule-icon.wechat {
  background: rgba(7,193,96,0.1);
  color: #07C160;
}

.rule-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rule-text {
  font-size: 26rpx;
  color: #374151;
  font-weight: 600;
}

.rule-note {
  font-size: 22rpx;
  color: #9CA3AF;
}

.bonus-tip {
  margin-top: 20rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(91,95,230,0.1), rgba(124,58,237,0.1));
  border-radius: 12rpx;
  text-align: center;
}

.bonus-tip text {
  font-size: 24rpx;
  color: #5B5FE6;
  font-weight: 600;
}

/* 平台选择 */
.platform-tabs {
  display: flex;
  gap: 16rpx;
}

.tab-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F9FAFB;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
}

/* 上传区域 */
.upload-area {
  width: 100%;
  height: 400rpx;
  background: #F9FAFB;
  border: 2rpx dashed #E5E7EB;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.upload-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.upload-icon {
  font-size: 80rpx;
  color: #D1D5DB;
  line-height: 1;
}

.upload-text {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
}

.upload-hint {
  font-size: 22rpx;
  color: #9CA3AF;
}

.upload-preview {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

/* 链接输入 */
.url-input-wrap {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  color: #374151;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.url-input {
  width: 100%;
  height: 80rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #374151;
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  border: none;
  font-size: 30rpx;
}

.submit-btn[disabled] {
  opacity: 0.5;
}

/* 记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-item {
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.platform-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.platform-badge.xiaohongshu {
  background: rgba(254,44,85,0.1);
  color: #FE2C55;
}

.platform-badge.douyin {
  background: rgba(0,0,0,0.05);
  color: #000;
}

.platform-badge.moments {
  background: rgba(7,193,96,0.1);
  color: #07C160;
}

.record-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.record-status.pending {
  background: rgba(245,158,11,0.1);
  color: #F59E0B;
}

.record-status.approved {
  background: rgba(16,185,129,0.1);
  color: #10B981;
}

.record-status.rejected {
  background: rgba(239,68,68,0.1);
  color: #EF4444;
}

.record-body {
  display: flex;
  gap: 16rpx;
}

.record-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.record-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.record-reward {
  font-size: 26rpx;
  color: #10B981;
  font-weight: 600;
}

.record-note {
  font-size: 22rpx;
  color: #EF4444;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
}
