<view class="page-recharge">
  <!-- 标签页切换 -->
  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 'vip' ? 'active' : ''}}"
      data-tab="vip"
      bind:tap="onTabChange"
    >
      <text>VIP会员</text>
    </view>
    <view
      class="tab-item {{activeTab === 'coins' ? 'active' : ''}}"
      data-tab="coins"
      bind:tap="onTabChange"
    >
      <text>雷达币充值</text>
    </view>
  </view>

  <!-- VIP订阅面板 -->
  <view wx:if="{{activeTab === 'vip'}}">
    <!-- 当前VIP状态 -->
    <view class="vip-status" wx:if="{{isVip}}">
      <text class="vip-status-text">当前: VIP会员</text>
      <text class="vip-status-expires">到期时间: {{vipExpiresAt}}</text>
    </view>

    <!-- VIP套餐选择 -->
    <view class="plan-list">
      <view
        class="plan-card {{selectedPlan === item.plan ? 'selected' : ''}}"
        wx:for="{{vipPlans}}"
        wx:key="plan"
        data-plan="{{item.plan}}"
        bind:tap="onSelectPlan"
      >
        <text class="plan-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
        <view class="plan-header">
          <text class="plan-label">{{item.label}}</text>
          <text class="plan-desc">{{item.desc}}</text>
        </view>
        <view class="plan-price-row">
          <text class="plan-price-sym">¥</text>
          <text class="plan-price">{{item.price}}</text>
          <text class="plan-per-day">约¥{{item.perDay}}/天</text>
        </view>
        <view class="plan-features">
          <text class="plan-feature" wx:for="{{item.features}}" wx:for-item="feat" wx:key="*this">{{feat}}</text>
        </view>
      </view>
    </view>

    <!-- 订阅按钮 -->
    <view class="action-section safe-bottom">
      <view class="btn-primary recharge-btn {{loading ? 'disabled' : ''}}" bind:tap="onSubscribe">
        {{loading ? '处理中...' : (isVip ? '续费VIP' : '立即开通VIP')}}
      </view>
      <text class="recharge-note">开通即表示同意《VIP服务协议》，到期后不自动续费</text>
    </view>
  </view>

  <!-- 雷达币充值面板 -->
  <view wx:if="{{activeTab === 'coins'}}">
    <!-- 当前余额 -->
    <view class="balance-section">
      <text class="balance-label">当前余额</text>
      <text class="balance-num">{{balance}}</text>
      <text class="balance-unit">雷达币</text>
    </view>

    <!-- 充值套餐 -->
    <view class="section-title">选择充值套餐</view>
    <view class="package-grid">
      <view
        class="package-item {{selectedCoinAmount === item.amount ? 'selected' : ''}}"
        wx:for="{{coinPackages}}"
        wx:key="amount"
        data-amount="{{item.amount}}"
        bind:tap="onSelectCoinPackage"
      >
        <text class="pkg-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
        <text class="pkg-coins">{{item.total}} 雷达币</text>
        <text class="pkg-bonus" wx:if="{{item.bonus > 0}}">含赠送 {{item.bonus}} 币</text>
        <text class="pkg-price">{{item.price}}</text>
      </view>
    </view>

    <!-- 充值按钮 -->
    <view class="action-section safe-bottom">
      <view class="btn-primary recharge-btn {{loading ? 'disabled' : ''}}" bind:tap="onRecharge">
        {{loading ? '处理中...' : '立即充值'}}
      </view>
      <text class="recharge-note">充值即表示同意《用户服务协议》</text>
    </view>
  </view>
</view>
