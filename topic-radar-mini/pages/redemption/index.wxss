.page-redemption {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 24rpx;
  display: block;
}

/* 输入区 */
.input-card {
  margin-top: 16rpx;
}

.input-row {
  margin-bottom: 24rpx;
}

.code-input {
  width: 100%;
  height: 88rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #1A1A2E;
  box-sizing: border-box;
}

.redeem-btn {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.redeem-btn.disabled {
  opacity: 0.6;
}

.input-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  text-align: center;
}

/* 兑换记录 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.record-item:last-child {
  border-bottom: none;
}

.record-code {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  letter-spacing: 2rpx;
}

.record-time {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 4rpx;
}

.record-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #10B981;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}
