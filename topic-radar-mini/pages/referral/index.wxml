<view class="page-referral">
  <!-- 头部 -->
  <view class="header">
    <text class="header-title">邀请好友 赚雷达币</text>
    <text class="header-desc">好友注册你得10币，好友得5币</text>
  </view>

  <!-- 奖励统计 -->
  <view class="stats-card card">
    <view class="stat-row">
      <view class="stat-col">
        <text class="stat-num">{{stats.totalReferred}}</text>
        <text class="stat-label">邀请人数</text>
      </view>
      <view class="stat-col">
        <text class="stat-num">{{stats.validReferred}}</text>
        <text class="stat-label">有效邀请</text>
      </view>
      <view class="stat-col">
        <text class="stat-num">{{stats.totalCoinsEarned}}</text>
        <text class="stat-label">获得雷达币</text>
      </view>
      <view class="stat-col" wx:if="{{stats.totalVipDaysEarned > 0}}">
        <text class="stat-num">{{stats.totalVipDaysEarned}}</text>
        <text class="stat-label">获得VIP天数</text>
      </view>
    </view>
  </view>

  <!-- 奖励规则 -->
  <view class="rules-card card">
    <text class="section-title">奖励规则</text>
    <view class="rule-item">
      <view class="rule-badge">注册</view>
      <view class="rule-content">
        <text class="rule-text">好友注册: 你+10币，好友+5币</text>
      </view>
    </view>
    <view class="rule-item">
      <view class="rule-badge">充值</view>
      <view class="rule-content">
        <text class="rule-text">好友首次充值: 你+20币</text>
      </view>
    </view>
    <view class="rule-item">
      <view class="rule-badge">VIP</view>
      <view class="rule-content">
        <text class="rule-text">好友开通VIP: 你+50币 + 7天VIP</text>
      </view>
    </view>
    <view class="rule-note">
      <text>每月最多50人有效邀请，好友需完成至少1次选题浏览</text>
    </view>
  </view>

  <!-- 我的等级 -->
  <view class="tier-card card">
    <text class="section-title">我的等级</text>
    <view class="tier-content">
      <view class="tier-badge {{myTier.tier}}">
        <text class="tier-icon">{{myTier.icon}}</text>
        <text class="tier-name">{{myTier.name}}</text>
      </view>
      <view class="tier-info">
        <view class="tier-progress-wrap">
          <text class="tier-progress-label">距离下一等级</text>
          <view class="tier-progress-bar">
            <view class="tier-progress-fill" style="width: {{myTier.progressPercent}}%"></view>
          </view>
          <text class="tier-progress-text">{{myTier.current}}/{{myTier.nextTarget}}</text>
        </view>
        <view class="tier-benefits">
          <text class="benefit-title">当前奖励</text>
          <text class="benefit-item">注册奖励: +{{myTier.signupBonus}}币</text>
          <text class="benefit-item">充值奖励: +{{myTier.rechargeBonus}}币</text>
          <text class="benefit-item" wx:if="{{myTier.vipBonus > 0}}">VIP奖励: +{{myTier.vipBonus}}天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 排行榜 -->
  <view class="leaderboard-card card">
    <text class="section-title">排行榜 TOP 20</text>
    <view class="leaderboard-list">
      <view class="leaderboard-item {{item.isCurrentUser ? 'current-user' : ''}}" wx:for="{{leaderboard}}" wx:key="userId">
        <view class="rank-badge rank-{{item.rank}}" wx:if="{{item.rank <= 3}}">
          {{item.rank}}
        </view>
        <text class="rank-text" wx:else>{{item.rank}}</text>
        <view class="user-info">
          <text class="user-name">{{item.userName}}</text>
          <text class="user-tier">{{item.tierName}}</text>
        </view>
        <text class="referral-count">{{item.referralCount}}人</text>
      </view>
    </view>
    <view class="my-rank" wx:if="{{myRank > 20}}">
      <text>我的排名: 第 {{myRank}} 名</text>
    </view>
  </view>

  <!-- 等级规则 -->
  <view class="tier-rules-card card">
    <text class="section-title">等级规则</text>
    <view class="tier-rule-list">
      <view class="tier-rule-item" wx:for="{{tierRules}}" wx:key="tier">
        <view class="tier-rule-header">
          <view class="tier-rule-badge {{item.tier}}">
            <text class="tier-rule-icon">{{item.icon}}</text>
            <text class="tier-rule-name">{{item.name}}</text>
          </view>
          <text class="tier-requirement">{{item.requirement}}</text>
        </view>
        <view class="tier-rule-rewards">
          <text class="reward-item">注册: +{{item.signupBonus}}币</text>
          <text class="reward-item">充值: +{{item.rechargeBonus}}币</text>
          <text class="reward-item" wx:if="{{item.vipBonus > 0}}">VIP: +{{item.vipBonus}}天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分享操作 -->
  <view class="share-actions">
    <button class="share-btn btn-primary" open-type="share">
      分享给好友
    </button>
    <view class="poster-btn" bind:tap="onPosterTap">
      生成邀请海报
    </view>
  </view>

  <!-- 邀请记录 -->
  <view class="record-card card" wx:if="{{referrals.length > 0}}">
    <text class="section-title">邀请记录</text>
    <view class="record-item" wx:for="{{referrals}}" wx:key="id">
      <view class="record-info">
        <text class="record-name">{{item.referredName || '用户'}}</text>
        <text class="record-time">{{item.createdAt}}</text>
      </view>
      <view class="record-status {{item.isValid ? 'valid' : 'pending'}}">
        <text>{{item.isValid ? '有效' : '待验证'}}</text>
      </view>
    </view>
  </view>

  <!-- 海报弹窗 -->
  <view class="poster-modal" wx:if="{{posterVisible}}" bind:tap="onClosePoster">
    <view class="poster-content" catchtap="">
      <canvas canvas-id="posterCanvas" class="poster-canvas" style="width:540rpx;height:960rpx;" />
      <view class="poster-actions">
        <view class="btn-primary poster-save-btn" bind:tap="onSavePoster">保存到相册</view>
        <view class="poster-close" bind:tap="onClosePoster">关闭</view>
      </view>
    </view>
  </view>
</view>
