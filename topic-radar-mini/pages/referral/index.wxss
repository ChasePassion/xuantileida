.page-referral {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #5B5FE6, #7C3AED);
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 统计 */
.stat-row {
  display: flex;
}

.stat-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #5B5FE6;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 奖励规则 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 24rpx;
  display: block;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
}

.rule-badge {
  width: 80rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(91,95,230,0.1);
  color: #5B5FE6;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: #374151;
}

.rule-note {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 分享操作 */
.share-actions {
  padding: 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.share-btn {
  width: 100%;
  border: none;
  font-size: 30rpx;
}

.poster-btn {
  width: 100%;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #5B5FE6;
  font-weight: 600;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #5B5FE6;
  box-sizing: border-box;
}

/* 邀请记录 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.record-item:last-child {
  border-bottom: none;
}

.record-name {
  font-size: 28rpx;
  color: #374151;
  display: block;
}

.record-time {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 4rpx;
}

.record-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.record-status.valid {
  background: rgba(16,185,129,0.1);
  color: #10B981;
}

.record-status.pending {
  background: #F3F4F6;
  color: #9CA3AF;
}

/* 海报弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.poster-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-canvas {
  border-radius: 16rpx;
  overflow: hidden;
}

.poster-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.poster-save-btn {
  width: 400rpx;
  text-align: center;
}

.poster-close {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  padding: 16rpx;
}
