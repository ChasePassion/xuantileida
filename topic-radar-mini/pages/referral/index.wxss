.page-referral {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #5B5FE6, #7C3AED);
  padding: 60rpx 40rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 统计 */
.stat-row {
  display: flex;
}

.stat-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #5B5FE6;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 奖励规则 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 24rpx;
  display: block;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
}

.rule-badge {
  width: 80rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(91,95,230,0.1);
  color: #5B5FE6;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.rule-text {
  font-size: 26rpx;
  color: #374151;
}

.rule-note {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 分享操作 */
.share-actions {
  padding: 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.share-btn {
  width: 100%;
  border: none;
  font-size: 30rpx;
}

.poster-btn {
  width: 100%;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #5B5FE6;
  font-weight: 600;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #5B5FE6;
  box-sizing: border-box;
}

/* 邀请记录 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.record-item:last-child {
  border-bottom: none;
}

.record-name {
  font-size: 28rpx;
  color: #374151;
  display: block;
}

.record-time {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 4rpx;
}

.record-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.record-status.valid {
  background: rgba(16,185,129,0.1);
  color: #10B981;
}

.record-status.pending {
  background: #F3F4F6;
  color: #9CA3AF;
}

/* 海报弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.poster-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-canvas {
  border-radius: 16rpx;
  overflow: hidden;
}

.poster-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.poster-save-btn {
  width: 400rpx;
  text-align: center;
}

.poster-close {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  padding: 16rpx;
}

/* 等级卡片 */
.tier-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.tier-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(91,95,230,0.1), rgba(124,58,237,0.1));
}

.tier-badge.bronze {
  background: linear-gradient(135deg, rgba(205,127,50,0.1), rgba(184,115,51,0.2));
}

.tier-badge.silver {
  background: linear-gradient(135deg, rgba(192,192,192,0.1), rgba(169,169,169,0.2));
}

.tier-badge.gold {
  background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(218,165,32,0.2));
}

.tier-badge.diamond {
  background: linear-gradient(135deg, rgba(185,242,255,0.1), rgba(64,224,208,0.2));
}

.tier-icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 12rpx;
}

.tier-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.tier-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tier-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tier-progress-label {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 600;
}

.tier-progress-bar {
  height: 12rpx;
  background: #F3F4F6;
  border-radius: 6rpx;
  overflow: hidden;
}

.tier-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5B5FE6, #7C3AED);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.tier-progress-text {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: right;
}

.tier-benefits {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.benefit-title {
  font-size: 24rpx;
  color: #1A1A2E;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.benefit-item {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}

/* 排行榜 */
.leaderboard-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.leaderboard-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.leaderboard-item.current-user {
  background: rgba(91,95,230,0.1);
  border: 2rpx solid #5B5FE6;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  flex-shrink: 0;
}

.rank-badge.rank-1 {
  background: linear-gradient(135deg, #FFD700, #DAA520);
  color: #fff;
}

.rank-badge.rank-2 {
  background: linear-gradient(135deg, #C0C0C0, #A9A9A9);
  color: #fff;
}

.rank-badge.rank-3 {
  background: linear-gradient(135deg, #CD7F32, #B87333);
  color: #fff;
}

.rank-text {
  width: 48rpx;
  text-align: center;
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 600;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 26rpx;
  color: #374151;
  font-weight: 600;
}

.user-tier {
  font-size: 22rpx;
  color: #9CA3AF;
}

.referral-count {
  font-size: 30rpx;
  color: #5B5FE6;
  font-weight: 700;
  flex-shrink: 0;
}

.my-rank {
  margin-top: 16rpx;
  padding: 16rpx;
  text-align: center;
  background: #F9FAFB;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #6B7280;
}

/* 等级规则 */
.tier-rule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tier-rule-item {
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.tier-rule-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.tier-rule-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.tier-rule-badge.bronze {
  background: rgba(205,127,50,0.1);
}

.tier-rule-badge.silver {
  background: rgba(192,192,192,0.1);
}

.tier-rule-badge.gold {
  background: rgba(255,215,0,0.1);
}

.tier-rule-badge.diamond {
  background: rgba(185,242,255,0.1);
}

.tier-rule-icon {
  font-size: 28rpx;
}

.tier-rule-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.tier-requirement {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 600;
}

.tier-rule-rewards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.reward-item {
  font-size: 22rpx;
  color: #6B7280;
}
