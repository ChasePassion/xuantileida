.page-square {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

.report-list {
  padding: 16rpx 0;
}

.report-item {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 24rpx 16rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.report-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  flex-shrink: 0;
}

.report-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.report-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  line-height: 1.4;
}

.report-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 8rpx;
}

.platform-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.meta-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.meta-sep {
  font-size: 22rpx;
  color: #D1D5DB;
}

.report-topic {
  margin-top: 8rpx;
}

.topic-tag {
  font-size: 22rpx;
  color: #5B5FE6;
  background: rgba(91,95,230,0.06);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.report-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
  margin-left: 12rpx;
  flex-shrink: 0;
}
