<view class="page-video-detail">
  <!-- 视频封面 -->
  <view class="video-cover" wx:if="{{video}}">
    <image class="cover-img" src="{{video.coverUrl}}" mode="aspectFill" />
    <view class="duration-badge">{{video.durationText}}</view>
  </view>

  <!-- 视频信息 -->
  <view class="video-info card" wx:if="{{video}}">
    <text class="video-title">{{video.title}}</text>
    <view class="video-meta">
      <text class="platform-badge badge badge-{{video.platform || 'primary'}}">{{video.platformName}}</text>
      <text class="creator-name" wx:if="{{video.creatorName}}">{{video.creatorName}}</text>
    </view>
    <view class="stats-bar">
      <view class="stat-item {{video.dataMasked ? 'masked' : ''}}">
        <text class="stat-icon">♥</text>
        <text>{{video.likesText}}</text>
      </view>
      <view class="stat-item {{video.dataMasked ? 'masked' : ''}}">
        <text class="stat-icon">💬</text>
        <text>{{video.commentsText}}</text>
      </view>
      <view class="stat-item {{video.dataMasked ? 'masked' : ''}}">
        <text class="stat-icon">↗</text>
        <text>{{video.sharesText}}</text>
      </view>
    </view>
    <view class="masked-banner" wx:if="{{video.dataMasked}}">
      <text class="masked-banner-text">免费版数据已隐藏，升级VIP查看真实数据</text>
    </view>
  </view>

  <!-- 拆解报告 -->
  <block wx:if="{{hasReport && report}}">
    <!-- 综合评分 -->
    <view class="card score-card">
      <view class="section-title">拆解评分</view>
      <view class="score-row">
        <view class="score-circle">
          <text class="score-num">{{report.overallScore}}</text>
          <text class="score-max">/10</text>
        </view>
        <view class="score-info">
          <text class="score-label">综合评分</text>
          <text class="unlock-count">{{report.unlockCount || 0}}人已解锁</text>
        </view>
      </view>
    </view>

    <!-- 雷达图 -->
    <view class="card" wx:if="{{report.dimensions && report.dimensions.length > 0}}">
      <view class="section-title">维度分析</view>
      <radar-chart dimensions="{{report.dimensions}}" size="{{560}}" />

      <!-- 维度评语（解锁后可见） -->
      <view class="dim-comments" wx:if="{{report.isUnlocked}}">
        <view class="dim-item" wx:for="{{report.dimensions}}" wx:key="dimension">
          <view class="dim-header">
            <text class="dim-label">{{item.label}}</text>
            <text class="dim-score">{{item.score}}</text>
          </view>
          <text class="dim-comment" wx:if="{{item.comment}}">{{item.comment}}</text>
        </view>
      </view>
    </view>

    <!-- 钩子深度分析（解锁后可见） -->
    <view class="card" wx:if="{{report.isUnlocked && report.hookAnalysis}}">
      <view class="section-title">钩子深度拆解</view>
      <view class="hook-analysis">
        <view class="hook-type-row">
          <view class="hook-badge hook-badge-text">{{report.hookAnalysis.textHookType}}</view>
          <view class="hook-badge hook-badge-visual">{{report.hookAnalysis.visualHookType}}</view>
          <view class="hook-strength">钩子强度 {{report.hookAnalysis.textHookStrength}}/10</view>
        </view>
        <view class="hook-detail-item">
          <text class="hook-detail-label">文案钩子</text>
          <text class="hook-detail-text">{{report.hookAnalysis.textHookContent}}</text>
        </view>
        <view class="hook-detail-item">
          <text class="hook-detail-label">视觉钩子</text>
          <text class="hook-detail-text">{{report.hookAnalysis.visualHookDesc}}</text>
        </view>
        <view class="hook-detail-item">
          <text class="hook-detail-label">文案x视觉配合</text>
          <text class="hook-detail-text">{{report.hookAnalysis.synergy}}</text>
        </view>
        <view class="hook-detail-item" wx:if="{{report.hookAnalysis.soundDesign}}">
          <text class="hook-detail-label">声音设计</text>
          <text class="hook-detail-text">{{report.hookAnalysis.soundDesign}}</text>
        </view>
      </view>
    </view>

    <!-- 脚本拆解（解锁后可见） -->
    <view class="card" wx:if="{{report.isUnlocked && report.scriptStructure}}">
      <view class="section-title">脚本结构拆解</view>
      <script-timeline segments="{{report.scriptStructure}}" />
    </view>

    <!-- 留存机制分析（解锁后可见） -->
    <view class="card" wx:if="{{report.isUnlocked && report.retentionAnalysis}}">
      <view class="section-title">留存机制分析</view>
      <view class="retention-section">
        <view class="retention-item" wx:if="{{report.retentionAnalysis.openLoops.length > 0}}">
          <text class="retention-label">开放回路</text>
          <view class="retention-tags">
            <text class="retention-tag" wx:for="{{report.retentionAnalysis.openLoops}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="retention-item" wx:if="{{report.retentionAnalysis.patternInterrupts.length > 0}}">
          <text class="retention-label">模式打断</text>
          <view class="retention-tags">
            <text class="retention-tag tag-orange" wx:for="{{report.retentionAnalysis.patternInterrupts}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="retention-item" wx:if="{{report.retentionAnalysis.curiosityGaps.length > 0}}">
          <text class="retention-label">悬念缺口</text>
          <view class="retention-tags">
            <text class="retention-tag tag-purple" wx:for="{{report.retentionAnalysis.curiosityGaps}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 病毒系数（解锁后可见） -->
    <view class="card" wx:if="{{report.isUnlocked && report.viralScore}}">
      <view class="section-title">病毒传播系数</view>
      <view class="viral-grid">
        <view class="viral-item">
          <text class="viral-num">{{report.viralScore.shareability}}</text>
          <text class="viral-label">传播力</text>
        </view>
        <view class="viral-item">
          <text class="viral-num">{{report.viralScore.commentBait}}</text>
          <text class="viral-label">评论诱饵</text>
        </view>
        <view class="viral-item">
          <text class="viral-num">{{report.viralScore.saveability}}</text>
          <text class="viral-label">收藏力</text>
        </view>
        <view class="viral-item viral-total">
          <text class="viral-num">{{report.viralScore.totalViralScore}}</text>
          <text class="viral-label">总分/70</text>
        </view>
      </view>
      <view class="viral-verdict">{{report.viralScore.viralVerdict}}</view>
      <text class="viral-reason" wx:if="{{report.viralScore.shareReason}}">传播分析: {{report.viralScore.shareReason}}</text>
    </view>

    <!-- 情感弧线（解锁后可见） -->
    <view class="card" wx:if="{{report.isUnlocked && report.emotionalArc}}">
      <view class="section-title">情感弧线</view>
      <view class="emotion-arc-type">{{report.emotionalArc.arcType}}</view>
      <text class="emotion-arc-desc">{{report.emotionalArc.arcDescription}}</text>
      <view class="emotion-keywords" wx:if="{{report.emotionalArc.triggerWords.length > 0}}">
        <text class="emotion-keyword" wx:for="{{report.emotionalArc.triggerWords}}" wx:key="*this">{{item}}</text>
      </view>
      <text class="emotion-peak" wx:if="{{report.emotionalArc.peakMoment}}">情绪峰值: {{report.emotionalArc.peakMoment}}</text>
    </view>

    <!-- 可复制要素（解锁后可见） -->
    <view class="card" wx:if="{{report.isUnlocked && report.replicableElements}}">
      <view class="section-title">可复制要素</view>
      <view class="replicate-framework" wx:if="{{report.replicableElements.templateFramework}}">
        <text class="framework-text">{{report.replicableElements.templateFramework}}</text>
      </view>
      <view class="replicate-group" wx:if="{{report.replicableElements.canCopy.length > 0}}">
        <text class="replicate-label replicate-green">可直接复用</text>
        <text class="replicate-item" wx:for="{{report.replicableElements.canCopy}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="replicate-group" wx:if="{{report.replicableElements.needAdapt.length > 0}}">
        <text class="replicate-label replicate-orange">需要调整</text>
        <text class="replicate-item" wx:for="{{report.replicableElements.needAdapt}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="replicate-group" wx:if="{{report.replicableElements.cannotCopy.length > 0}}">
        <text class="replicate-label replicate-gray">无法复制</text>
        <text class="replicate-item" wx:for="{{report.replicableElements.cannotCopy}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 创作者实操建议（解锁后可见） -->
    <view class="card" wx:if="{{report.isUnlocked && report.creatorTips}}">
      <view class="section-title">创作实操建议</view>
      <view class="tips-section" wx:if="{{report.creatorTips.hookTemplates.length > 0}}">
        <text class="tips-label">开头模板</text>
        <view class="tips-list">
          <text class="tips-item" wx:for="{{report.creatorTips.hookTemplates}}" wx:key="*this">{{index + 1}}. {{item}}</text>
        </view>
      </view>
      <view class="tips-section" wx:if="{{report.creatorTips.titleTemplates.length > 0}}">
        <text class="tips-label">标题模板</text>
        <view class="tips-list">
          <text class="tips-item" wx:for="{{report.creatorTips.titleTemplates}}" wx:key="*this">{{index + 1}}. {{item}}</text>
        </view>
      </view>
      <view class="tips-section" wx:if="{{report.creatorTips.abTestSuggestions.length > 0}}">
        <text class="tips-label">A/B测试建议</text>
        <view class="tips-list">
          <text class="tips-item" wx:for="{{report.creatorTips.abTestSuggestions}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <view class="tips-section" wx:if="{{report.creatorTips.commonMistakes.length > 0}}">
        <text class="tips-label tips-warn">常见错误</text>
        <view class="tips-list">
          <text class="tips-item tips-warn-item" wx:for="{{report.creatorTips.commonMistakes}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- AI分析总结（解锁后可见） -->
    <view class="card summary-card" wx:if="{{report.isUnlocked && report.summary}}">
      <view class="section-title">AI分析总结</view>
      <text class="summary-text">{{report.summary}}</text>
    </view>

    <!-- 解锁按钮 -->
    <view class="unlock-bar safe-bottom" wx:if="{{!report.isUnlocked}}">
      <view class="unlock-hint">解锁查看完整维度评语和脚本拆解</view>
      <view class="btn-primary unlock-btn" bind:tap="onUnlockTap">
        解锁报告 · {{report.unlockPrice}} 雷达币
      </view>
    </view>
  </block>

  <!-- 无拆解报告 -->
  <view class="card" wx:if="{{!hasReport && video}}">
    <view class="empty-state">
      <text class="empty-text">该视频暂无拆解报告</text>
    </view>
  </view>

  <!-- 解锁弹窗 -->
  <unlock-modal
    visible="{{showUnlockModal}}"
    price="{{report.unlockPrice}}"
    balance="{{balance}}"
    loading="{{unlockLoading}}"
    bind:confirm="onUnlockConfirm"
    bind:close="onModalClose"
  />
</view>
