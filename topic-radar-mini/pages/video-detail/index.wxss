.page-video-detail {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 180rpx;
}

/* 封面 */
.video-cover {
  position: relative;
  width: 100%;
  height: 420rpx;
  background: #000;
}

.video-cover .cover-img {
  width: 100%;
  height: 100%;
}

.duration-badge {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 视频信息 */
.video-info {
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
  border-radius: 24rpx 24rpx var(--radius-lg) var(--radius-lg);
}

.video-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}

.video-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.creator-name {
  font-size: 24rpx;
  color: #9CA3AF;
}

.stats-bar {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
}

.stat-icon {
  font-size: 26rpx;
}

/* 评分卡 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.score-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B5FE6, #7C3AED);
  display: flex;
  align-items: baseline;
  justify-content: center;
  flex-shrink: 0;
}

.score-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
}

.score-max {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.score-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.score-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.unlock-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 维度评语 */
.dim-comments {
  margin-top: 32rpx;
}

.dim-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.dim-item:last-child {
  border-bottom: none;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dim-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.dim-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #5B5FE6;
}

.dim-comment {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* 摘要 */
.summary-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
}

/* 解锁底栏 */
.unlock-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.unlock-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  margin-bottom: 12rpx;
}

.unlock-btn {
  width: 100%;
  box-sizing: border-box;
}
