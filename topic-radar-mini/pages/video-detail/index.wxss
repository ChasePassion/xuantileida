.page-video-detail {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 180rpx;
}

/* 封面 */
.video-cover {
  position: relative;
  width: 100%;
  height: 420rpx;
  background: #000;
}

.video-cover .cover-img {
  width: 100%;
  height: 100%;
}

.duration-badge {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 视频信息 */
.video-info {
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
  border-radius: 24rpx 24rpx var(--radius-lg) var(--radius-lg);
}

.video-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}

.video-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.creator-name {
  font-size: 24rpx;
  color: #9CA3AF;
}

.stats-bar {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
}

.stat-icon {
  font-size: 26rpx;
}

.stat-item.masked {
  color: #D1D5DB;
}

.masked-banner {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: #FFF7ED;
  border-radius: 12rpx;
  border: 1rpx solid #FDE68A;
}

.masked-banner-text {
  font-size: 22rpx;
  color: #92400E;
}

/* 评分卡 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.score-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B5FE6, #7C3AED);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.score-max {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1;
}

.score-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.score-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.unlock-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 维度评语 */
.dim-comments {
  margin-top: 32rpx;
}

.dim-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.dim-item:last-child {
  border-bottom: none;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dim-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.dim-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #5B5FE6;
}

.dim-comment {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* 摘要 */
.summary-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
}

.summary-card {
  margin-bottom: 40rpx;
}

/* ===== 钩子深度分析 ===== */
.hook-type-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.hook-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.hook-badge-text {
  background: rgba(239,68,68,0.1);
  color: #EF4444;
}

.hook-badge-visual {
  background: rgba(124,58,237,0.1);
  color: #7C3AED;
}

.hook-strength {
  font-size: 24rpx;
  font-weight: 700;
  color: #F59E0B;
  margin-left: auto;
}

.hook-detail-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.hook-detail-item:last-child {
  border-bottom: none;
}

.hook-detail-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #9CA3AF;
  display: block;
  margin-bottom: 6rpx;
}

.hook-detail-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

/* ===== 留存机制 ===== */
.retention-item {
  margin-bottom: 20rpx;
}

.retention-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 10rpx;
}

.retention-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.retention-tag {
  font-size: 22rpx;
  color: #3B82F6;
  background: rgba(59,130,246,0.08);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

.retention-tag.tag-orange {
  color: #F59E0B;
  background: rgba(245,158,11,0.08);
}

.retention-tag.tag-purple {
  color: #7C3AED;
  background: rgba(124,58,237,0.08);
}

/* ===== 病毒系数 ===== */
.viral-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.viral-item {
  flex: 1;
  text-align: center;
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 16rpx 8rpx;
}

.viral-item.viral-total {
  background: linear-gradient(135deg, rgba(91,95,230,0.08), rgba(124,58,237,0.08));
}

.viral-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #5B5FE6;
  display: block;
}

.viral-total .viral-num {
  color: #7C3AED;
}

.viral-label {
  font-size: 20rpx;
  color: #9CA3AF;
  display: block;
  margin-top: 4rpx;
}

.viral-verdict {
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #10B981;
  padding: 12rpx;
  background: rgba(16,185,129,0.06);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.viral-reason {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
}

/* ===== 情感弧线 ===== */
.emotion-arc-type {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 700;
  color: #EC4899;
  background: rgba(236,72,153,0.08);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.emotion-arc-desc {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}

.emotion-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.emotion-keyword {
  font-size: 22rpx;
  color: #EC4899;
  background: rgba(236,72,153,0.06);
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
}

.emotion-peak {
  font-size: 24rpx;
  color: #6B7280;
  font-style: italic;
}

/* ===== 可复制要素 ===== */
.replicate-framework {
  background: linear-gradient(135deg, rgba(91,95,230,0.06), rgba(124,58,237,0.06));
  border: 1rpx solid rgba(91,95,230,0.15);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.framework-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #5B5FE6;
  line-height: 1.6;
}

.replicate-group {
  margin-bottom: 16rpx;
}

.replicate-label {
  font-size: 22rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.replicate-green { color: #10B981; }
.replicate-orange { color: #F59E0B; }
.replicate-gray { color: #9CA3AF; }

.replicate-item {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.8;
  display: block;
  padding-left: 20rpx;
  position: relative;
}

.replicate-item::before {
  content: '·';
  position: absolute;
  left: 0;
  font-weight: 700;
}

/* ===== 创作建议 ===== */
.tips-section {
  margin-bottom: 24rpx;
}

.tips-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #5B5FE6;
  display: block;
  margin-bottom: 10rpx;
}

.tips-label.tips-warn {
  color: #EF4444;
}

.tips-item {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.7;
  display: block;
  padding: 6rpx 0;
}

.tips-warn-item {
  color: #92400E;
  background: #FFF7ED;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

/* 解锁底栏 */
.unlock-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.unlock-hint {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  margin-bottom: 12rpx;
}

.unlock-btn {
  width: 100%;
  box-sizing: border-box;
}
